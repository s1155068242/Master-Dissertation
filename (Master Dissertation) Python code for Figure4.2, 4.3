#Define all the function needed 

def EinvCQM(x,OmegaM):#coupled Quintessencia model
        return 1/np.sqrt( OmegaM*(1+x)**3+ 1-OmegaM )
  
def integr(x,OmegaM):#integrate 1/E , return a value
   #result , error = quad(1/E, 0, x, args=(OmegaM,lamb))
   [integral, error] = quad(lambda x: EinvCQM(x,OmegaM), 0, x)
   return integral

def integrlist(x,OmegaM):#integrate 1/E , return an array
   #result , error = quad(1/E, 0, x, args=(OmegaM,lamb))
   integral = np.zeros(len(x))
   for i in range(len(x)):
       integral[i] = integr(x[i],OmegaM)
   return integral
 
def dl(x,OmegaM,h):# return a value
    Ho = 299792458*h/(2.99792458*3.085678*10**25) #s^-1
    return c*(1+x)*integr(x,OmegaM)/Ho

def dllist(x,OmegaM,h):# return an array
    Ho = 299792458*h/(2.99792458*3.085678*10**25)#s^-1
    dllista = np.zeros(len(x))
    dllista = c*(1+x)*integrlist(x,OmegaM)/Ho
    return dllista

def dlgw(x,OmegaM,M,h):# return a value
    return np.sqrt( (2*np.sqrt(6)+M)/(2*np.sqrt(6)+M*EinvCQM(x,OmegaM)))*dl(x,OmegaM,h)

def dllistgw(x,OmegaM,M,h):# return an array
    dllista = np.zeros(len(x))
    dllista = np.sqrt( (2*np.sqrt(6)+M)/(2*np.sqrt(6)+M*EinvCQM(x,OmegaM)))*dllist(x,OmegaM,h)
    return dllista

def r(x):
    a = 0
    if x <= 1:
        a = 1+2*x
    elif 1 < x < 5:   
        a = (15-3*x)/4
    elif x > 5:
        a = 0
    return a
#probability density function
def flisa(x,alpha,beta,gama):#no event in z<0.1
    return gama*(x/9)**(alpha-1)*(1-x/9)**(beta-1)

def sigmaphoto(x):
    sigmaph=np.zeros(len(x))
    for i in range(len(x)):
        if(x[i]>2):
            sigmaph[i] = 0.03*(1+x[i])
        elif(x[i]<=2):
            sigmaph[i] = 0 
    return sigmaph
    
def deltadl_uncert(x,OmegaM,M,h,step):
    Ho = 299792458*h/(2.99792458*3.085678e25)#s^-1
    Fdelens =np.zeros(len(x))
    sigmalens=np.zeros(len(x))
    sigmadelens=np.zeros(len(x))
    sigmav=np.zeros(len(x))
    sigmainst=np.zeros(len(x))
    for i in range(len(x)):
        Fdelens[i] = 1-0.3/(np.pi/2)*np.arctan(x[i]/0.073)
        sigmalens[i] = 0.066*dlgw(x[i],OmegaM,M,h)*((1-(1+x[i])**-0.25)/0.25)**1.8
        sigmav[i] = (1+c*(1+x[i])**2*EinvCQM(x[i],OmegaM)/(Ho*dlgw(x[i],OmegaM,M,h)))*(1.6203896e-20/c)*dlgw(x[i],OmegaM,M,h)
    sigmainst = 0.05*dllistgw(x,OmegaM,M,h)**2/36.6
    sigmadelens = sigmalens*Fdelens
    #sigmalisa2 = sigmadelens**2+sigmav**2+sigmainst**2+((dllistgw(x+step,OmegaM,M,h)-dllistgw(x-step,OmegaM,M,h))*sigmaphoto(x)/(2*step))**2
    sigmalisa2 =sigmadelens**2+sigmav**2+sigmainst**2+(derivative(dllistgw, x, dx=1e-6, args=(OmegaM,M,h)) *sigmaphoto(x))**2 
    return np.sqrt(sigmalisa2)

#finite different method, return an array
#creat first dvviative method for Fisher Matrix 
def dfunc_ome(randomzlist,OmegaM,M,h,step):
    return (dllistgw(randomzlist,OmegaM+step,M,h) - dllistgw(randomzlist,OmegaM-step,M,h))/(2*step)
def dfunc_M(randomzlist,OmegaM,M,h,step):
    return (dllistgw(randomzlist,OmegaM,M+step,h) - dllistgw(randomzlist,OmegaM,M-step,h))/(2*step)
def dfunc_h(randomzlist,OmegaM,M,h,step):
    return (dllistgw(randomzlist,OmegaM,M,h+step) - dllistgw(randomzlist,OmegaM,M,h-step))/(2*step)

